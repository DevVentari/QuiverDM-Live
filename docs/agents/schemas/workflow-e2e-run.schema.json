{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://quiverdm.local/schemas/workflow-e2e-run.schema.json",
  "title": "WorkflowE2ERun",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "workflow",
    "runId",
    "startedAt",
    "endedAt",
    "status",
    "command",
    "assertions",
    "evidencePaths"
  ],
  "properties": {
    "workflow": {
      "type": "string"
    },
    "runId": {
      "type": "string"
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "endedAt": {
      "type": "string",
      "format": "date-time"
    },
    "durationMs": {
      "type": "number"
    },
    "status": {
      "type": "string",
      "enum": ["passed", "failed"]
    },
    "command": {
      "type": "string"
    },
    "assertions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "passed"],
        "properties": {
          "name": {
            "type": "string"
          },
          "passed": {
            "type": "boolean"
          },
          "detail": {
            "type": "string"
          }
        }
      }
    },
    "evidencePaths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
