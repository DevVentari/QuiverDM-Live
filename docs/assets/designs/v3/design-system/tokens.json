{
  "$schema": "https://design-tokens.org/tokens.json",
  "name": "QuiverDM Design Tokens",
  "version": "1.0.0",
  "description": "Dark, warm, hand-inked design system for a Dungeon Master's command center. Type: Kalam (display) + Hanken Grotesk (body) + mono (data).",
  "font": {
    "display": { "value": "'Kalam', cursive", "comment": "titles, character names, narration" },
    "body": { "value": "'Hanken Grotesk', system-ui, sans-serif", "comment": "UI + body copy" },
    "mono": { "value": "ui-monospace, 'SFMono-Regular', Menlo, monospace", "comment": "numbers, labels, codes" }
  },
  "color": {
    "surface": {
      "bg": { "value": "#0a0707" },
      "surface": { "value": "#16110e" },
      "surface2": { "value": "#100b09" },
      "rail": { "value": "#0d0908" },
      "card": { "value": "#1b1512" },
      "onAccent": { "value": "#1a0f06" }
    },
    "ink": {
      "strong": { "value": "#f6ead8" },
      "default": { "value": "#ece2d4" },
      "secondary": { "value": "#cdbfae" },
      "muted": { "value": "#9c8a76" },
      "faint": { "value": "#7f6f5e" },
      "faintest": { "value": "#5a4f45" }
    },
    "accent": {
      "hi": { "value": "#f0d6b2" },
      "text": { "value": "#e9b277" },
      "bright": { "value": "#e0944a" },
      "base": { "value": "#d98a3d" },
      "deep": { "value": "#c97a30" },
      "deeper": { "value": "#b8662a" }
    },
    "success": {
      "hi": { "value": "#bcd1a4" },
      "bright": { "value": "#8fc466" },
      "base": { "value": "#7fae5a" },
      "deep": { "value": "#5f8f45" },
      "deeper": { "value": "#3f5f2a" }
    },
    "danger": {
      "hi": { "value": "#e6a99f" },
      "bright": { "value": "#e0584a" },
      "base": { "value": "#c4453a" },
      "deep": { "value": "#8a2f26" }
    },
    "warn": {
      "hi": { "value": "#ef9a5f" },
      "base": { "value": "#cf6f2a" },
      "deep": { "value": "#a8401f" }
    },
    "arcane": {
      "hi": { "value": "#d6c8e4" },
      "bright": { "value": "#cbb8e0" },
      "base": { "value": "#b08fd0" },
      "deep": { "value": "#7a5fb0" }
    },
    "border": {
      "default": { "value": "rgba(255,235,205,0.10)" },
      "strong": { "value": "rgba(255,235,205,0.16)" },
      "faint": { "value": "rgba(255,235,205,0.06)" },
      "accent": { "value": "rgba(217,138,61,0.40)" },
      "accentStrong": { "value": "rgba(217,138,61,0.50)" }
    }
  },
  "gradient": {
    "panel": { "value": "linear-gradient(180deg, #16110e, #100b09)" },
    "card": { "value": "linear-gradient(180deg, rgba(255,255,255,.035), rgba(0,0,0,.15))" },
    "accent": { "value": "linear-gradient(180deg, #e0944a, #c97a30)" },
    "success": { "value": "linear-gradient(90deg, #5f8f45, #8fc466)" },
    "danger": { "value": "linear-gradient(90deg, #8a2f26, #c4453a)" }
  },
  "space": {
    "1": { "value": "4px" }, "2": { "value": "8px" }, "3": { "value": "12px" },
    "4": { "value": "16px" }, "5": { "value": "20px" }, "6": { "value": "24px" },
    "8": { "value": "32px" }, "10": { "value": "40px" }
  },
  "radius": {
    "sm": { "value": "8px" }, "md": { "value": "10px" }, "lg": { "value": "12px" },
    "xl": { "value": "14px" }, "2xl": { "value": "16px" }, "panel": { "value": "18px" },
    "pill": { "value": "20px" }, "phone": { "value": "30px" }, "full": { "value": "9999px" }
  },
  "shadow": {
    "card": { "value": "0 30px 70px rgba(0,0,0,.4)" },
    "panel": { "value": "0 40px 90px rgba(0,0,0,.6)" },
    "token": { "value": "0 4px 14px rgba(0,0,0,.5)" },
    "accent": { "value": "0 8px 20px rgba(217,138,61,.3)" },
    "glowActive": { "value": "0 0 0 1px rgba(217,138,61,.9), 0 0 26px rgba(217,138,61,.4)" }
  },
  "motion": {
    "duration": {
      "fast": { "value": "150ms", "comment": "hover, press" },
      "base": { "value": "250ms", "comment": "entrance, fade" },
      "slow": { "value": "400ms", "comment": "travel, hand-off" },
      "ambient": { "value": "2400ms", "comment": "breathing loops" }
    },
    "easing": {
      "out": { "value": "cubic-bezier(.2,.8,.2,1)", "comment": "90% of UI" },
      "spring": { "value": "cubic-bezier(.34,1.56,.64,1)", "comment": "pops, pips" },
      "inout": { "value": "cubic-bezier(.65,0,.35,1)", "comment": "ambient loops" }
    }
  },
  "type": {
    "display2xl": { "value": { "font": "display", "size": "56px", "weight": 700, "lineHeight": 1.0 } },
    "displayXl": { "value": { "font": "display", "size": "30px", "weight": 700, "lineHeight": 1.0 } },
    "title": { "value": { "font": "display", "size": "22px", "weight": 700, "lineHeight": 1.05 } },
    "narration": { "value": { "font": "display", "size": "18px", "style": "italic", "lineHeight": 1.55 } },
    "bodyLg": { "value": { "font": "body", "size": "16px", "weight": 400, "lineHeight": 1.55 } },
    "body": { "value": { "font": "body", "size": "14px", "weight": 400, "lineHeight": 1.55 } },
    "bodySm": { "value": { "font": "body", "size": "12px", "weight": 400, "lineHeight": 1.5 } },
    "label": { "value": { "font": "mono", "size": "9px", "letterSpacing": "0.16em", "case": "uppercase" } }
  },
  "icons": {
    "source": "dnd set — single-path, solid-fill, 100x100 SVG glyphs",
    "tintMethod": "CSS mask (mask-image + background-color), never <img>, so glyphs recolor to state",
    "categories": ["ability", "attribute", "campaign", "class", "combat", "condition", "damage", "dice", "entity", "game", "hp", "location", "monster", "movement", "proficiency", "skill", "slot", "spell", "target", "util", "weapon"]
  }
}
