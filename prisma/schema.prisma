// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  password          String? @db.Text // For credentials provider

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id              String            @id @default(cuid())
  name            String?
  email           String?           @unique
  emailVerified   DateTime?
  image           String?

  // Profile fields for collaboration
  displayName     String?           // Public display name
  bio             String?           @db.Text // Creator/player bio

  // Onboarding tracking
  onboardingCompleted Boolean       @default(false)
  onboardingStep      String?       // Current step: 'welcome', 'profile', 'first_campaign', 'complete'
  inviteCodeUsed      String?       // Which beta invite code was used

  // Subscription and usage limits
  tier                String        @default("free") // free, pro, team
  stripeCustomerId    String?       @unique // Stripe customer ID for billing
  stripeSubscriptionId String?      @unique // Stripe subscription ID
  subscriptionStatus  String?       // active, canceled, past_due, etc.
  subscriptionEndsAt  DateTime?     // When current subscription ends

  // Relations
  usage               UserUsage?
  accounts        Account[]
  sessions        Session[]
  campaigns       Campaign[]        // Campaigns user owns (legacy, kept for migration)
  campaignMemberships CampaignMember[] // Campaigns user is a member of
  characters      Character[]       // Player-owned characters
  homebrewContent HomebrewContent[]
  homebrewPDFs    HomebrewPDF[]
  settings        UserSettings?

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model UserSettings {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Encrypted API keys
  openaiApiKey            String?  @db.Text // Encrypted
  anthropicApiKey         String?  @db.Text // Encrypted
  huggingfaceToken        String?  @db.Text // Encrypted
  dndBeyondCobaltCookie   String?  @db.Text // Encrypted

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Invite-only registration system
model InviteCode {
  id        String    @id @default(cuid())
  code      String    @unique // The actual invite code
  usedBy    String?   // User ID who used this code
  usedAt    DateTime? // When it was used
  createdAt DateTime  @default(now())
  expiresAt DateTime? // Optional expiration

  @@index([code])
  @@index([usedBy])
}

// ============================================================================
// Multi-User Collaboration Enums
// ============================================================================

enum CampaignRole {
  OWNER     // Full control, can delete campaign
  CO_DM     // Almost full control, cannot delete or transfer
  PLAYER    // Manage own character, view shared content
  SPECTATOR // Read-only access to shared content
}

enum ContentVisibility {
  PRIVATE   // Only creator can see
  CAMPAIGN  // Visible to campaign members
  PUBLIC    // Visible to all users
  UNLISTED  // Anyone with link can view
}

// ============================================================================
// QuiverDM Core Models
// ============================================================================

model Campaign {
  id               String                      @id @default(cuid())
  name             String
  slug             String                      @unique // URL-friendly slug generated from name
  description      String?                     @db.Text
  bannerUrl        String?
  status           String                      @default("active") // active, paused, completed

  // Legacy owner field (kept for backward compatibility during migration)
  userId           String
  user             User                        @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Multi-user collaboration
  members          CampaignMember[]            // All campaign members with roles
  invites          CampaignInvite[]            // Pending invites
  inviteCode       String?                     @unique // Quick join code
  isPublic         Boolean                     @default(false) // Discoverable in search

  // Campaign settings (JSON for flexibility)
  settings         Json?                       // { allowPlayerNotes, shareRecaps, etc. }

  // Content relations
  gameSessions     GameSession[]
  npcs             NPC[]
  glossary         Json?                       // Campaign-specific glossary for transcription
  homebrewContent  CampaignHomebrewContent[]   // Many-to-many with homebrew
  homebrewPDFs     HomebrewPDF[]               // Campaign-specific PDFs
  players          Player[]                    // Legacy player records (will migrate to Character)
  characters       CampaignCharacter[]         // Characters in this campaign
  encounterPlans   EncounterPlan[]             // Pre-session encounter designs

  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt

  @@index([userId])
  @@index([status])
  @@index([slug])
  @@index([inviteCode])
  @@index([isPublic])
}

// Campaign membership - who belongs to a campaign and their role
model CampaignMember {
  id          String       @id @default(cuid())
  campaignId  String
  campaign    Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        CampaignRole @default(PLAYER)
  joinedAt    DateTime     @default(now())
  invitedBy   String?      // userId who invited them

  // Granular permission overrides (beyond role defaults)
  canViewNPCSecrets    Boolean @default(false)
  canEditNPCs          Boolean @default(false)
  canManageSessions    Boolean @default(false)
  canInviteMembers     Boolean @default(false)

  @@unique([campaignId, userId])
  @@index([campaignId])
  @@index([userId])
  @@index([role])
}

// Campaign invites - pending invitations
model CampaignInvite {
  id          String       @id @default(cuid())
  campaignId  String
  campaign    Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  // Invite can be via code OR direct email
  code        String?      @unique // Random code for link sharing
  email       String?               // Direct email invitation

  role        CampaignRole @default(PLAYER) // Role they'll receive on join
  createdBy   String                // userId who created the invite
  message     String?      @db.Text // Optional invite message

  expiresAt   DateTime?            // Optional expiration
  usedAt      DateTime?            // When invite was accepted
  usedBy      String?              // userId who accepted

  createdAt   DateTime     @default(now())

  @@index([campaignId])
  @@index([code])
  @@index([email])
}

// ============================================================================
// Character System (Player-owned characters)
// ============================================================================

// Character status in a campaign
enum CharacterStatus {
  PENDING   // Awaiting DM approval
  ACTIVE    // Currently playing
  RETIRED   // Voluntarily retired
  DECEASED  // Character died
  REMOVED   // Removed by DM
}

model Character {
  id              String    @id @default(cuid())

  // Ownership - Characters are owned by users (players)
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Portability - Can this character be used in multiple campaigns?
  isPortable      Boolean   @default(true)

  // Core identity
  name            String
  race            String?
  class           String?
  subclass        String?
  level           Int       @default(1)
  background      String?

  // Visuals
  portraitUrl     String?

  // Core stats (structured for easy access)
  abilityScores   Json?     // { str: 10, dex: 14, con: 12, int: 8, wis: 15, cha: 13 }
  hitPoints       Json?     // { current: 25, max: 30, temp: 0 }
  armorClass      Int?
  speed           Int?      @default(30)
  proficiencyBonus Int?     @default(2)

  // Character details
  features        Json?     // Class/race features, abilities
  proficiencies   Json?     // Skills, tools, weapons, armor, saves
  inventory       Json?     // Equipment and items
  spellcasting    Json?     // Spellcasting info, prepared spells, slots
  currency        Json?     // { cp: 0, sp: 0, ep: 0, gp: 100, pp: 0 }

  // Backstory and notes
  backstory       String?   @db.Text
  personalityTraits String? @db.Text
  ideals          String?   @db.Text
  bonds           String?   @db.Text
  flaws           String?   @db.Text
  notes           String?   @db.Text  // Player's private notes

  // Additional D&D 5e data (JSON for flexibility)
  languages       Json?     // ["Common", "Elvish"]
  senses          Json?     // { darkvision: 60, passivePerception: 14 }
  resistances     Json?     // { damage: ["fire"], conditions: ["charmed"] }
  hitDice         Json?     // [{ die: "d10", total: 5, used: 2 }]
  savingThrows    Json?     // { strength: { proficient: true }, ... }
  classes         Json?     // [{ name: "Fighter", subclass: "Champion", level: 5 }]
  appearance      Json?     // { height, weight, eyes, skin, hair }

  // D&D Beyond sync
  dndBeyondId     String?   @unique
  dndBeyondUrl    String?
  lastSyncedAt    DateTime?

  // Full raw data (for complete D&D Beyond import preservation)
  rawData         Json?     // Complete character data from import

  // Campaign associations
  campaignCharacters  CampaignCharacter[]

  // Homebrew content links
  homebrewItems       CharacterItem[]
  homebrewSpells      CharacterSpell[]
  homebrewFeats       CharacterFeat[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([name])
  @@index([dndBeyondId])
}

// Join table: Character in a Campaign
// This allows the same character to be in multiple campaigns (if portable)
// and tracks campaign-specific data like status and DM notes
model CampaignCharacter {
  id           String          @id @default(cuid())

  campaignId   String
  campaign     Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  characterId  String
  character    Character       @relation(fields: [characterId], references: [id], onDelete: Cascade)

  // Status in this campaign
  status       CharacterStatus @default(PENDING)
  isActive     Boolean         @default(true)  // Currently selected character for player

  // DM-only notes (not visible to player)
  dmNotes      String?         @db.Text

  // Campaign-specific overrides (optional)
  // E.g., if character has different level or items in this campaign
  campaignData Json?

  joinedAt     DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([campaignId, characterId])
  @@index([campaignId])
  @@index([characterId])
  @@index([status])
}

model GameSession {
  id               String              @id @default(cuid())
  campaignId       String
  campaign         Campaign            @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  sessionNumber    Int
  date             DateTime            @default(now())
  title            String?
  quickNotes       String?             @db.Text
  recap            String?             @db.Text
  status           String              @default("active") // active, completed, cancelled
  recordings       SessionRecording[]
  transcripts      Transcript[]
  encounters       Encounter[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@unique([campaignId, sessionNumber])
  @@index([campaignId])
  @@index([date])
}

model Encounter {
  id           String                 @id @default(cuid())
  sessionId    String
  session      GameSession            @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name         String
  round        Int                    @default(1)
  status       String                 @default("active") // active|complete
  log          Json?                  // [{round, events: [{participantId, action, value}]}]
  participants EncounterParticipant[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@index([sessionId])
}

model EncounterParticipant {
  id          String    @id @default(cuid())
  encounterId String
  encounter   Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  npcId       String?
  name        String
  type        String    // pc|npc|monster
  initiative  Int       @default(0)
  hp          Int
  maxHp       Int
  conditions  Json      @default("[]") // D&D 5e condition strings
  isAlive     Boolean   @default(true)
  updatedAt   DateTime  @updatedAt

  @@index([encounterId])
}

model NPC {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name        String
  description String?  @db.Text
  faction     String?
  role        String?
  secrets     String?  @db.Text
  imageUrl    String?
  stats       Json? // Flexible stats object
  tags        String[] // For filtering
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([campaignId])
  @@index([name])
}

model Player {
  id            String   @id @default(cuid())
  campaignId    String
  campaign      Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name          String // Player's real name
  characterName String
  characterRace String?
  characterClass String?
  level         Int      @default(1)
  imageUrl      String?
  notes         String?  @db.Text
  backstory     String?  @db.Text

  // D&D Beyond integration
  dndBeyondUrl  String?  // Public character URL for re-syncing
  lastSyncedAt  DateTime?

  // Full character data as JSON (for flexibility)
  characterData Json? // Stores ability scores, skills, features, inventory, etc.

  // Structured character content
  spells        PlayerSpell[]
  feats         PlayerFeat[]
  items         PlayerItem[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([campaignId])
}

// D&D 5e Spell Model (from D&D Beyond or manual entry)
model Spell {
  id              String        @id @default(cuid())
  name            String
  level           Int           // 0 for cantrips, 1-9 for spell levels
  school          String        // Abjuration, Conjuration, etc.
  castingTime     String        // "1 action", "1 bonus action", etc.
  range           String        // "30 feet", "Self", etc.
  components      String[]      // ["V", "S", "M"]
  materialComponents String?    @db.Text // Material component description
  duration        String        // "Instantaneous", "Concentration, up to 1 minute", etc.
  description     String        @db.Text
  higherLevels    String?       @db.Text // Description of casting at higher levels
  ritual          Boolean       @default(false)
  concentration   Boolean       @default(false)
  classes         String[]      // Classes that can cast this spell
  source          String        @default("PHB") // PHB, XGE, TCE, etc.
  dndBeyondId     String?       @unique // D&D Beyond spell ID

  players         PlayerSpell[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([name])
  @@index([level])
  @@index([school])
}

// Join table: Player has many Spells
model PlayerSpell {
  id              String   @id @default(cuid())
  playerId        String
  player          Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  spellId         String
  spell           Spell    @relation(fields: [spellId], references: [id], onDelete: Cascade)
  prepared        Boolean  @default(false) // Is this spell prepared?
  alwaysPrepared  Boolean  @default(false) // Always prepared (racial/class feature)
  addedAt         DateTime @default(now())

  @@unique([playerId, spellId])
  @@index([playerId])
  @@index([spellId])
}

// D&D 5e Feat Model
model Feat {
  id              String       @id @default(cuid())
  name            String
  description     String       @db.Text
  prerequisites   String?      @db.Text // Prerequisites for taking this feat
  source          String       @default("PHB") // PHB, XGE, TCE, etc.
  dndBeyondId     String?      @unique // D&D Beyond feat ID

  players         PlayerFeat[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([name])
}

// Join table: Player has many Feats
model PlayerFeat {
  id              String   @id @default(cuid())
  playerId        String
  player          Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  featId          String
  feat            Feat     @relation(fields: [featId], references: [id], onDelete: Cascade)
  addedAt         DateTime @default(now())

  @@unique([playerId, featId])
  @@index([playerId])
  @@index([featId])
}

// D&D 5e Item Model
model Item {
  id              String       @id @default(cuid())
  name            String
  type            String       // "Weapon", "Armor", "Potion", "Wondrous Item", etc.
  rarity          String       @default("Common") // Common, Uncommon, Rare, Very Rare, Legendary, Artifact
  description     String       @db.Text
  weight          Float?       // Weight in pounds
  cost            String?      // "50 gp", "500 gp", etc.
  requiresAttunement Boolean   @default(false)
  properties      String[]     // Item properties (magical, consumable, etc.)
  source          String       @default("PHB") // PHB, DMG, XGE, etc.
  dndBeyondId     String?      @unique // D&D Beyond item ID

  players         PlayerItem[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([name])
  @@index([type])
  @@index([rarity])
}

// Join table: Player has many Items (with quantity, equipped status)
model PlayerItem {
  id              String   @id @default(cuid())
  playerId        String
  player          Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  itemId          String
  item            Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  quantity        Int      @default(1)
  equipped        Boolean  @default(false)
  attuned         Boolean  @default(false)
  notes           String?  @db.Text // Player-specific notes about the item
  addedAt         DateTime @default(now())

  @@unique([playerId, itemId])
  @@index([playerId])
  @@index([itemId])
}

// Session Recording & Transcription Models
model SessionRecording {
  id               String      @id @default(cuid())
  sessionId        String
  session          GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type             String // 'audio', 'video', 'pdf'
  originalUrl      String
  extractedAudioUrl String?    // URL of extracted audio (for videos), null if original was audio
  fileSize         Int // in bytes
  durationSeconds  Int? // null for PDFs
  processingStatus String      @default("queued") // queued, processing, completed, failed
  errorMessage     String?     @db.Text
  originalDeleted  Boolean     @default(false) // true if original video was deleted after transcription
  transcripts      Transcript[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([sessionId])
  @@index([processingStatus])
}

model Transcript {
  id              String            @id @default(cuid())
  sessionId       String
  session         GameSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  recordingId     String?
  recording       SessionRecording? @relation(fields: [recordingId], references: [id], onDelete: SetNull)
  rawText         String            @db.Text
  correctedText   String?           @db.Text
  speakers        Json? // Array of speaker objects
  timestamps      Json? // Array of timestamp objects
  glossaryMatches Json? // Matched glossary terms
  formats         Json? // Generated formats (discord, table, web)
  language        String?
  languageProbability Float?
  durationSeconds Float?
  hasSpeakers     Boolean           @default(false)
  source          String            @default("upload") // 'upload' | 'live'
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([sessionId])
  @@index([recordingId])
}

model TranscriptionJob {
  id                      String   @id @default(cuid())
  sessionId               String
  recordingId             String?
  filePath                String
  modelSize               String   @default("medium")
  language                String?
  useGPU                  Boolean  @default(true)
  useSpeakers             Boolean  @default(false)
  speakerNames            String[] // Array of speaker names
  numSpeakers             Int?
  status                  String   @default("queued") // queued, processing, completed, failed
  progress                Int      @default(0) // 0-100
  currentChunk            Int      @default(0)
  totalChunks             Int      @default(0)
  currentStep             String?  // 'extracting_audio', 'splitting_chunks', 'transcribing', 'diarizing', 'saving', 'uploading_audio', 'submitting_to_assemblyai', 'waiting_for_assemblyai', 'downloading_result'
  currentSubStep          String?  // Detailed substep like 'loading_model', 'aligning_timestamps', 'detecting_speakers'
  estimatedTimeRemaining  Int?     // Seconds remaining (estimated)
  progressDetails         Json?    // Additional progress metadata (batch info, speaker count, etc.)
  errorMessage            String?  @db.Text
  transcriptId            String?  // Resulting transcript ID
  assemblyaiTranscriptId  String?  // AssemblyAI transcript ID for polling
  provider                String   @default("assemblyai") // 'assemblyai' | 'whisperx'
  startedAt               DateTime?
  completedAt             DateTime?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([sessionId])
  @@index([status])
  @@index([createdAt])
}

// Homebrew Content Models
// Note: PDF parsing removed. Content can be created manually or via D&D Beyond import.
model HomebrewContent {
  id           String                      @id @default(cuid())
  userId       String // Homebrew is owned by user
  user         User                        @relation(fields: [userId], references: [id], onDelete: Cascade)

  type         String // 'item', 'creature', 'spell', 'location', 'subclass', 'feat', 'rule', 'race', 'class', 'background', 'character'
  name         String
  data         Json // Flexible data structure based on type
  images       String[] // Array of image URLs
  tags         String[] // For categorization
  searchText   String                      @db.Text // Denormalized for full-text search

  // D&D Beyond integration
  dndBeyondId  String? // D&D Beyond ID for syncing
  dndBeyondUrl String? // D&D Beyond URL for reference

  // Source tracking
  sourceType   String                      @default("manual") // 'manual', 'dndbeyond_import', 'pdf_extraction'
  sourcePdfId  String?
  sourcePdf    HomebrewPDF?                @relation(fields: [sourcePdfId], references: [id], onDelete: SetNull)
  imageMetadata Json? // Metadata for each image (source, page number, etc.)
  extractionPageNumber Int? // Which PDF page this content was extracted from

  campaigns    CampaignHomebrewContent[] // Many-to-many with campaigns
  characterItems  CharacterItem[]
  characterSpells CharacterSpell[]
  characterFeats  CharacterFeat[]
  createdAt    DateTime                    @default(now())
  updatedAt    DateTime                    @updatedAt

  @@index([userId])
  @@index([type])
  @@index([name])
  @@index([dndBeyondId])
  @@index([sourceType])
  @@index([sourcePdfId])
  @@index([userId, type])
  @@index([userId, createdAt(sort: Desc)])
}

// Join table: Character has many Items (from Homebrew)
model CharacterItem {
  id          String          @id @default(cuid())
  characterId String
  character   Character       @relation(fields: [characterId], references: [id], onDelete: Cascade)
  homebrewId  String
  homebrew    HomebrewContent @relation(fields: [homebrewId], references: [id], onDelete: Cascade)

  quantity    Int             @default(1)
  equipped    Boolean         @default(false)
  attuned     Boolean         @default(false)
  notes       String?         @db.Text
  addedAt     DateTime        @default(now())

  @@unique([characterId, homebrewId])
  @@index([characterId])
  @@index([homebrewId])
}

// Join table: Character has many Spells (from Homebrew)
model CharacterSpell {
  id             String          @id @default(cuid())
  characterId    String
  character      Character       @relation(fields: [characterId], references: [id], onDelete: Cascade)
  homebrewId     String
  homebrew       HomebrewContent @relation(fields: [homebrewId], references: [id], onDelete: Cascade)

  prepared       Boolean         @default(false)
  alwaysPrepared Boolean         @default(false)
  addedAt        DateTime        @default(now())

  @@unique([characterId, homebrewId])
  @@index([characterId])
  @@index([homebrewId])
}

// Join table: Character has many Feats (from Homebrew)
model CharacterFeat {
  id          String          @id @default(cuid())
  characterId String
  character   Character       @relation(fields: [characterId], references: [id], onDelete: Cascade)
  homebrewId  String
  homebrew    HomebrewContent @relation(fields: [homebrewId], references: [id], onDelete: Cascade)

  addedAt     DateTime        @default(now())

  @@unique([characterId, homebrewId])
  @@index([characterId])
  @@index([homebrewId])
}

// Join table for many-to-many relationship between campaigns and homebrew
model CampaignHomebrewContent {
  id              String          @id @default(cuid())
  campaignId      String
  campaign        Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  homebrewId      String
  homebrew        HomebrewContent @relation(fields: [homebrewId], references: [id], onDelete: Cascade)
  addedAt         DateTime        @default(now())

  @@unique([campaignId, homebrewId])
  @@index([campaignId])
  @@index([homebrewId])
}

// Homebrew PDFs - Store and convert to markdown for AI processing
model HomebrewPDF {
  id                  String    @id @default(cuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignId          String?   // Optional - PDFs can be in personal library or campaign-specific
  campaign            Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  // File metadata
  filename            String
  fileSize            Int       // in bytes
  mimeType            String    @default("application/pdf")
  r2Url               String    // Cloudflare R2 storage URL for the PDF

  // Marker processing
  markdownContent     String?   @db.Text // Converted markdown (for AI processing)
  markdownR2Url       String?   // Optional: Store markdown in R2 if very large
  markerProcessed     Boolean   @default(false)
  markerMetadata      Json?     // { pages, processingTime, imagesExtracted, etc. }
  useLLM              Boolean   @default(false) // Whether to use LLM enhancement for better extraction
  extractedImages     Int       @default(0) // Count of extracted images
  imageExtractionStatus String  @default("pending") // pending, processing, completed, failed

  // Processing status
  processingStatus    String    @default("pending") // pending, processing, completed, failed
  errorMessage        String?   @db.Text
  processingStartedAt DateTime?
  processingEndedAt   DateTime?
  isRulesSource       Boolean   @default(false)
  indexedAt           DateTime?

  extractedContent    HomebrewContent[]

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([userId])
  @@index([campaignId])
  @@index([processingStatus])
  @@index([createdAt])
}

// Feedback system for closed beta
model Feedback {
  id          String   @id @default(cuid())
  userId      String   // User who submitted feedback
  type        String   // 'bug', 'feature', 'improvement', 'other'
  category    String?  // 'transcription', 'pdf', 'ui', 'performance', 'other'
  title       String
  description String   @db.Text
  rating      Int?     // Optional 1-5 rating
  metadata    Json?    // Browser info, URL, etc.
  status      String   @default("new") // new, acknowledged, in_progress, resolved, wont_fix
  adminNotes  String?  @db.Text // Internal notes from admin
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

// Usage tracking for tier limits
model UserUsage {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Current billing period
  periodStart             DateTime @default(now())
  periodEnd               DateTime // 30 days from periodStart

  // Transcription usage (in seconds)
  transcriptionSeconds    Int      @default(0)
  transcriptionLimit      Int      @default(1800) // 30 minutes for free tier

  // PDF uploads
  pdfUploads              Int      @default(0)
  pdfUploadLimit          Int      @default(5) // 5 PDFs for free tier

  // Campaigns owned
  campaignsOwned          Int      @default(0)
  campaignLimit           Int      @default(1) // 1 campaign for free tier

  // Last reset date (for tracking monthly resets)
  lastResetAt             DateTime @default(now())

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([userId])
  @@index([periodEnd])
}

model ImageGenerationJob {
  id           String    @id @default(cuid())
  homebrewId   String
  userId       String
  prompt       String    @db.Text
  provider     String    @default("auto") // 'comfyui', 'replicate', 'dalle', 'auto'
  status       String    @default("queued") // queued, processing, completed, failed
  progress     Int       @default(0)
  workflowId   String?   // ComfyUI workflow/prompt ID
  resultUrl    String?
  errorMessage String?   @db.Text
  metadata     Json?
  createdAt    DateTime  @default(now())
  completedAt  DateTime?
  updatedAt    DateTime  @updatedAt

  @@index([homebrewId, userId, status])
  @@index([status, createdAt])
  @@index([userId])
}

// ============================================================================
// Encounter Builder — pre-session planning models
// ============================================================================

model EncounterPlan {
  id               String                 @id @default(cuid())
  campaignId       String
  campaign         Campaign               @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name             String
  aiPrompt         String?                @db.Text   // original user prompt
  sceneDescription String?                @db.Text   // AI-generated prose
  tacticalNotes    String?                @db.Text   // AI DM tips
  difficulty       String                 @default("medium") // easy|medium|hard|deadly
  partySize        Int?
  partyLevel       Int?
  xpBudget         Int?                              // target XP budget
  totalXp          Int?                              // actual raw XP of selected creatures
  adjustedXp       Int?                              // XP after encounter multiplier
  creatures        EncounterPlanCreature[]
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@index([campaignId])
}

model EncounterPlanCreature {
  id          String        @id @default(cuid())
  planId      String
  plan        EncounterPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  name        String
  count       Int           @default(1)
  cr          String?                     // "1/4", "1", "10"
  xp          Int?                        // XP per creature
  sourceType  String                      // 'srd' | 'npc' | 'homebrew'
  sourceId    String?                     // NPC id or HomebrewContent id
  statBlock   Json?                       // Full stat block snapshot
  createdAt   DateTime      @default(now())

  @@index([planId])
}
