{
  "manifest_version": 3,
  "name": "QuiverDM — D&D Beyond Sync",
  "version": "1.0.0",
  "description": "Automatically sync your D&D Beyond session to QuiverDM.",
  "permissions": [
    "cookies",
    "identity",
    "storage"
  ],
  "host_permissions": [
    "https://www.dndbeyond.com/*",
    "https://quiverdm.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "QuiverDM Sync",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "quiverdm-sync@blakewales.au",
      "strict_min_version": "109.0"
    }
  }
}
