# ============================================================
# QuiverDM — Environment Variables
# Copy to .env.local for development, or set in Vercel for production.
# ============================================================

# Auth
NEXTAUTH_URL=http://localhost:3847
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Database (PostgreSQL with pgvector)
# Dev: docker-compose postgres on port 5433
# Prod: Neon.tech free tier — run CREATE EXTENSION IF NOT EXISTS vector; first
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/quiverdm

# Redis (BullMQ + caching)
# Dev: docker-compose redis on port 6380
# Prod: Upstash free tier — use rediss:// TLS URL
REDIS_URL=redis://localhost:6380

# MeiliSearch (full-text search)
# Dev: docker-compose meilisearch on port 7701
# Prod: Meilisearch Cloud free tier — copy Host URL + Default Admin API Key
MEILI_URL=http://localhost:7701
MEILI_MASTER_KEY=

# Cloudflare R2 (file storage)
# Dev: leave both unset (defaults to local disk)
# Prod: set both to r2
STORAGE_MODE=local
NEXT_PUBLIC_STORAGE_MODE=local
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=quiverdm
# Optional: custom domain for public R2 access (images, PDFs)
# R2_PUBLIC_URL=https://files.quiverdm.com

# WebSocket server
WS_PORT=3004
NEXT_PUBLIC_WS_URL=ws://localhost:3004

# Stripe (billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_TEAM_PRICE_ID=price_...

# Email (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@quiverdm.com

# AssemblyAI (live transcription)
ASSEMBLYAI_API_KEY=

# Ollama (local AI — homebrew extraction, custom section detection)
OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2  # Optional: override default model

# Docling (PDF-to-markdown conversion)
DOCLING_URL=http://localhost:5001

# Image generation
# Options: auto (tries providers in order), replicate, comfyui
IMAGE_GENERATION_DEFAULT_PROVIDER=auto
REPLICATE_API_KEY=

# ComfyUI (local GPU image generation — optional)
COMFYUI_URL=http://localhost:8188
COMFYUI_ENABLED=false
COMFYUI_MODEL=sd_xl_base_1.0.safetensors

# Admin
# Comma-separated list of email addresses with admin access
ADMIN_EMAILS=you@example.com
