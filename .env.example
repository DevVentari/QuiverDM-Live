DOCLING_URL=http://localhost:5001

# ComfyUI (local GPU image generation)
COMFYUI_URL=http://localhost:8188
COMFYUI_ENABLED=false
COMFYUI_MODEL=sd_xl_base_1.0.safetensors

# Cloud image generation
REPLICATE_API_KEY=your_replicate_api_key_here
IMAGE_GENERATION_DEFAULT_PROVIDER=auto

# WebSocket Server
WS_PORT=3004
NEXT_PUBLIC_WS_URL=ws://localhost:3004

# AssemblyAI (for live transcription)
ASSEMBLYAI_API_KEY=your_assemblyai_api_key

# Ollama (local AI)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=        # Optional: override model used for custom section detection (default: llama3.2)
