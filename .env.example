# ============================================================
# QuiverDM — Environment Variables
# Copy to .env.local and fill in the secret values (passwords / API keys).
#
# DEV TOPOLOGY: there is NO local docker. All backing services (Postgres,
# Redis, MeiliSearch, Ollama, crawl4ai, Docling, WebSocket server + the 25
# BullMQ workers) run always-on via PM2 on the homelab at 192.168.1.21.
# The dev machine only runs `npm run dev`. The hosts/ports below are already
# pointed at the homelab — you only need to fill in the **** secrets.
# ============================================================

# Auth
NEXTAUTH_URL=http://localhost:3847
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Feature flags
# v3 redesign (parallel /v3 tree). 0 = off (default). Testers opt in via the
# `qdm_v3` cookie regardless; this build-wide flag is for preview deploys.
NEXT_PUBLIC_QDM_V3=0

# Database (PostgreSQL 16 + pgvector, homelab LXC 206)
# Prod: Neon.tech — run CREATE EXTENSION IF NOT EXISTS vector; first
DATABASE_URL=postgresql://quiverdm:CHANGE_ME@192.168.1.21:5432/quiverdm

# Redis (BullMQ + caching, homelab LXC 206)
# Prod: Upstash — use rediss:// TLS URL
REDIS_URL=redis://192.168.1.21:6379

# MeiliSearch (full-text search, homelab LXC 206)
# Prod: Meilisearch Cloud — copy Host URL + Default Admin API Key
MEILI_URL=http://192.168.1.21:7700
MEILI_MASTER_KEY=

# Cloudflare R2 (file storage)
# Dev: leave both unset (defaults to local disk)
# Prod: set both to r2
STORAGE_MODE=local
NEXT_PUBLIC_STORAGE_MODE=local
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=quiverdm
# Optional: custom domain for public R2 access (images, PDFs)
# R2_PUBLIC_URL=https://files.quiverdm.com

# WebSocket server (homelab LXC 206)
WS_PORT=3004
NEXT_PUBLIC_WS_URL=ws://192.168.1.21:3004
# Internal WS URL the Discord voice bot dials for the live-caption feed (A3).
# Defaults to NEXT_PUBLIC_WS_URL; set to ws://localhost:3004 when co-located.
WS_INTERNAL_URL=ws://localhost:3004

# Stripe (billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_TEAM_PRICE_ID=price_...

# Email (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@quiverdm.com

# Live transcription provider: `local` (self-hosted WhisperLive, free) or
# `assemblyai` (cloud, billed). Defaults to `local`.
STT_REALTIME_PROVIDER=local

# WhisperLive (local realtime STT — homelab GPU box). Used when provider=local.
WHISPERLIVE_URL=ws://192.168.1.21:9090
WHISPERLIVE_MODEL=large-v3

# Batch multi-track transcription provider: `whisperx` (local, on the homelab GPU,
# default) or `assemblyai` (cloud fallback). WhisperX needs the Python env on the
# worker host; each track is one speaker so no diarization is run per track.
MULTITRACK_STT=whisperx
WHISPERX_MODEL=medium
WHISPERX_DEVICE=cuda

# AssemblyAI (used only when STT_REALTIME_PROVIDER=assemblyai or MULTITRACK_STT=
# assemblyai)
ASSEMBLYAI_API_KEY=

# Ollama (local AI — homebrew extraction, custom section detection; homelab)
OLLAMA_BASE_URL=http://192.168.1.21:11434
# OLLAMA_MODEL=llama3.2  # Optional: override default model

# Docling (PDF-to-markdown conversion; homelab)
DOCLING_URL=http://192.168.1.21:5001

# crawl4ai (DDB private character browser extraction; homelab)
CRAWL4AI_URL=http://192.168.1.21:5002

# Image generation
# Options: auto (tries providers in order), replicate, comfyui
IMAGE_GENERATION_DEFAULT_PROVIDER=auto
REPLICATE_API_KEY=

# ComfyUI (local GPU image generation — optional)
COMFYUI_URL=http://localhost:8188
COMFYUI_ENABLED=false
COMFYUI_MODEL=sd_xl_base_1.0.safetensors

# Admin
# Comma-separated list of email addresses with admin access
ADMIN_EMAILS=you@example.com

# Discord (feedback overlay)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_FEEDBACK_CHANNEL_ID=

# GitHub (feedback issue creation — optional)
GITHUB_TOKEN=
GITHUB_FEEDBACK_REPO=DevVentari/quiverdm-feedback

# Analytics (PostHog)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
