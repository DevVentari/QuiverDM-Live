# QuiverDM Local Development Environment
# Copy this file to .env.local and fill in your values
#
# For detailed setup: docs/LOCAL_SETUP.md
# For API keys: docs/API_KEYS_SETUP_GUIDE.md

# =============================================================================
# DATABASE (Docker PostgreSQL)
# =============================================================================
# Default: Uses local Docker PostgreSQL (docker-compose up -d)
DATABASE_URL="postgresql://quiverdm:localdev@localhost:5433/quiverdm"

# =============================================================================
# AUTHENTICATION
# =============================================================================
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="local-dev-secret-change-in-production"

# Google OAuth (optional - can use email/password locally)
# Setup: docs/OAUTH_SETUP_GUIDE.md
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# =============================================================================
# AI SERVICES
# =============================================================================
# OpenAI (for AI extraction) - https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# Anthropic Claude (for summaries) - https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""

# HuggingFace (for speaker diarization) - https://huggingface.co/settings/tokens
HF_TOKEN=""

# Ollama (local AI - optional) - http://localhost:11434
OLLAMA_API_URL="http://localhost:11434"

# =============================================================================
# LOCAL SERVICES (Docker)
# =============================================================================
# Redis - job queue (docker-compose up -d redis)
REDIS_URL="redis://localhost:6380"

# MeiliSearch - search (docker-compose up -d meilisearch)
MEILISEARCH_URL="http://localhost:7701"
MEILISEARCH_KEY="masterKey"

# =============================================================================
# STORAGE
# =============================================================================
# Local filesystem storage (default for development)
STORAGE_MODE="local"
LOCAL_STORAGE_PATH="./uploads"

# R2 Storage (for production - leave empty for local dev)
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET_NAME=""

# =============================================================================
# WORKER CONFIGURATION
# =============================================================================
PDF_WORKER_CONCURRENCY="2"

# =============================================================================
# NOTES
# =============================================================================
# 1. Never commit .env.local to git
# 2. Run: docker-compose up -d (starts PostgreSQL, Redis, MeiliSearch)
# 3. Run: npm run db:push (initializes database)
# 4. Run: npm run dev (starts the app)
# 5. For PDF processing: npm run worker:pdf (separate terminal)
