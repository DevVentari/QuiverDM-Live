# QuiverDM Environment Variables
# Copy this file to .env.local and fill in your actual values
# See docs/API_KEYS_SETUP_GUIDE.md for detailed instructions

# =============================================================================
# DATABASE (Supabase PostgreSQL)
# =============================================================================
# Get from: https://supabase.com/dashboard/project/_/settings/database
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres"

# =============================================================================
# AUTHENTICATION (NextAuth.js)
# =============================================================================
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# =============================================================================
# OAUTH PROVIDERS
# =============================================================================
# See docs/OAUTH_SETUP_GUIDE.md for detailed setup instructions

# Google OAuth - https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub OAuth - https://github.com/settings/developers
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Discord OAuth - https://discord.com/developers/applications
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# =============================================================================
# AI SERVICES
# =============================================================================
# OpenAI - https://platform.openai.com/api-keys
OPENAI_API_KEY=""
OPENAI_ORG_ID=""  # Optional

# Anthropic Claude - https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""

# Google Gemini - https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# Ollama (Local AI) - http://localhost:11434
OLLAMA_API_URL="http://localhost:11434"

# =============================================================================
# STORAGE (Cloudflare R2)
# =============================================================================
# Get from: https://dash.cloudflare.com/?to=/:account/r2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="quiverdm-media-dev"
R2_PUBLIC_URL=""

# =============================================================================
# SUPABASE (Database + Auth + Storage)
# =============================================================================
# Get from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# =============================================================================
# OPTIONAL SERVICES (Can be added later)
# =============================================================================

# Redis (Local Docker or Upstash for production)
# Local Docker: Use default values below (redis runs on port 6380)
# Production: Get from https://console.upstash.com/
REDIS_HOST="localhost"
REDIS_PORT="6380"
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""

# PDF Worker Configuration
PDF_WORKER_CONCURRENCY="2"  # Max concurrent PDF processing jobs

# Search (MeiliSearch) - Using local Docker for development
MEILISEARCH_HOST="http://localhost:7701"
MEILISEARCH_MASTER_KEY="masterKey"
MEILISEARCH_SEARCH_KEY=""
MEILISEARCH_ADMIN_KEY=""

# Analytics (PostHog) - https://app.posthog.com/signup
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# Monitoring (Sentry) - https://sentry.io/signup/
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG="quiverdm"
SENTRY_PROJECT="quiverdm-web"
SENTRY_AUTH_TOKEN=""

# Email (Resend) - https://resend.com/signup
EMAIL_FROM="noreply@localhost"
EMAIL_SERVER_HOST="smtp.resend.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="resend"
EMAIL_SERVER_PASSWORD=""

# =============================================================================
# MCP SERVERS (Model Context Protocol)
# =============================================================================
# GitHub MCP Server - https://github.com/settings/tokens
# Required scopes: repo, read:org
GITHUB_PERSONAL_ACCESS_TOKEN=""

# =============================================================================
# DEVELOPMENT OVERRIDES
# =============================================================================
NODE_ENV="development"
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# =============================================================================
# NOTES
# =============================================================================
# 1. Never commit this file to git (it's in .gitignore)
# 2. For production, set these in Vercel environment variables
# 3. See docs/API_KEYS_SETUP_GUIDE.md for step-by-step setup instructions
# 4. Rotate all keys every 90 days for security
# 5. Use different keys for development and production
