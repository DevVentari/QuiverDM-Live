DATABASE_URL=            # same homelab Postgres as the root app
NEXTAUTH_URL=http://localhost:3005
NEXTAUTH_SECRET=         # MUST equal the root app's NEXTAUTH_SECRET (shared JWT sessions)
AUTH_COOKIE_DOMAIN=      # empty locally; .quiverdm.com in production
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Storage — must match the worker. Unset = local disk (dev); r2 = Cloudflare R2 (prod).
STORAGE_MODE=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

REDIS_URL=            # same Redis as the workers (redis://192.168.1.21:6379 in prod)
ENCRYPTION_KEY=       # MUST equal the main app's ENCRYPTION_KEY (shared encrypted columns)
CRAWL4AI_URL=         # http://192.168.1.21:5002 — DDB campaign page scraper
