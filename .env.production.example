# ============================================================
# QuiverDM Production Environment Template
# Copy to .env and fill in all values before deploying
# ============================================================

# --- Database ---
# Railway Postgres URL (includes pgvector)
DATABASE_URL=postgresql://postgres:password@host:5432/quiverdm?schema=public

# --- Cache / Queues ---
REDIS_URL=redis://host:6379

# --- Auth ---
# Your Vercel production URL (no trailing slash)
NEXTAUTH_URL=https://your-app.vercel.app
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_TEAM_PRICE_ID=price_...

# --- Email (Resend) ---
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@yourdomain.com

# --- Admin ---
# Comma-separated list of admin email addresses
ADMIN_EMAILS=admin@yourdomain.com

# Optional: Discord webhook for beta feedback notifications
# DISCORD_FEEDBACK_WEBHOOK_URL=https://discord.com/api/webhooks/...

# --- Search (MeiliSearch) ---
MEILI_URL=https://search.yourdomain.com
# Generate with: openssl rand -base64 32
MEILI_MASTER_KEY=

# --- PDF Processing (Docling) ---
DOCLING_URL=https://docling.yourdomain.com

# --- AI (Ollama) ---
OLLAMA_BASE_URL=https://ollama.yourdomain.com

# --- Transcription (AssemblyAI) ---
ASSEMBLYAI_API_KEY=

# --- File Storage (Cloudflare R2) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=quiverdm-uploads
R2_PUBLIC_URL=https://uploads.yourdomain.com

# --- App ---
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# --- Analytics (PostHog) ---
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# --- Cloudflare Tunnel (optional, for self-hosted VPS deployment) ---
# Get from: Cloudflare Zero Trust > Networks > Tunnels > Create Tunnel
CLOUDFLARE_TUNNEL_TOKEN=

# ============================================================
# Deployment Notes
# ============================================================
# 1. Run: npm run db:push (against production DATABASE_URL)
# 2. Run: npm run setup:stripe (creates/finds Stripe products)
# 3. Run: npm run check:launch (validates all integrations)
# 4. Run: npm run generate-beta-invites (first invite batch)
# ============================================================
