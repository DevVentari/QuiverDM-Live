# =============================================================================
# QuiverDM — Production Environment Variables
# =============================================================================
# Copy this file to .env.production and fill in the actual values.
# NEVER commit .env.production to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
# Connection string for PostgreSQL. In docker-compose.prod.yml, this is
# overridden to use the internal Docker network hostname.
DATABASE_URL="postgresql://quiverdm:CHANGE_ME@postgres:5432/quiverdm"
POSTGRES_USER="quiverdm"
POSTGRES_PASSWORD="CHANGE_ME"
POSTGRES_DB="quiverdm"

# ---------------------------------------------------------------------------
# Redis (BullMQ job queue)
# ---------------------------------------------------------------------------
# Connection string for Redis. Overridden in docker-compose.prod.yml.
REDIS_URL="redis://redis:6379"

# ---------------------------------------------------------------------------
# NextAuth
# ---------------------------------------------------------------------------
# The canonical URL of your application (no trailing slash)
NEXTAUTH_URL="https://app.quiverdm.com"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# ---------------------------------------------------------------------------
# OAuth Providers
# ---------------------------------------------------------------------------
# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub OAuth — https://github.com/settings/developers
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Discord OAuth — https://discord.com/developers/applications
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# ---------------------------------------------------------------------------
# MeiliSearch (full-text search)
# ---------------------------------------------------------------------------
MEILI_URL="http://meilisearch:7700"
# Generate a strong master key for production
MEILI_MASTER_KEY=""

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
# "local" for filesystem, "r2" for Cloudflare R2
STORAGE_MODE="local"

# Cloudflare R2 (only needed if STORAGE_MODE=r2)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# ---------------------------------------------------------------------------
# AI Providers
# ---------------------------------------------------------------------------
# Local Ollama (default — set URL if running externally)
OLLAMA_BASE_URL="http://host.docker.internal:11434"

# Gemini (optional — used as fallback/alternative)
GEMINI_API_KEY=""

# OpenAI (optional — used as fallback/alternative)
OPENAI_API_KEY=""

# Anthropic (optional)
ANTHROPIC_API_KEY=""

# ---------------------------------------------------------------------------
# Stripe (payments)
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRO_PRICE_ID=""
STRIPE_TEAM_PRICE_ID=""

# ---------------------------------------------------------------------------
# Admin
# ---------------------------------------------------------------------------
# Comma-separated list of email addresses with admin access
ADMIN_EMAILS=""

# ---------------------------------------------------------------------------
# Email (optional)
# ---------------------------------------------------------------------------
EMAIL_FROM="noreply@quiverdm.com"
EMAIL_SERVER_HOST=""
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""

# ---------------------------------------------------------------------------
# Monitoring (optional)
# ---------------------------------------------------------------------------
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# ---------------------------------------------------------------------------
# Analytics (optional)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
